{
  "name": "lumen-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Provider-portable learning platform monorepo",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "analyze": "pnpm --filter @lumen/web analyze",
    "build": "turbo run build",
    "build:verify": "node scripts/run-with-verification-environment.mjs pnpm build",
    "build:portable": "pnpm --filter @lumen/web build:portable",
    "db:deploy:beta": "node scripts/hosted-database.mjs deploy beta",
    "db:deploy:preview": "node scripts/hosted-database.mjs deploy preview",
    "db:reset": "supabase db reset --local",
    "db:start": "supabase start",
    "db:status": "supabase status",
    "db:stop": "supabase stop",
    "db:types": "node scripts/generate-database-types.mjs",
    "db:types:check": "node scripts/generate-database-types.mjs --check",
    "db:verify:beta": "node scripts/hosted-database.mjs verify beta",
    "db:verify:preview": "node scripts/hosted-database.mjs verify preview",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0 && node scripts/check-boundaries.mjs",
    "secret:scan": "secretlint \"**/*\"",
    "test": "vitest run --coverage",
    "test:a11y": "node scripts/run-with-local-supabase-environment.mjs pnpm run test:a11y:configured",
    "test:a11y:configured": "playwright test --config=playwright.a11y.config.ts",
    "test:db": "supabase test db --local && node scripts/test-srs-concurrency.mjs",
    "test:e2e": "node scripts/run-with-local-supabase-environment.mjs pnpm run test:e2e:configured",
    "test:e2e:configured": "playwright test --config=playwright.config.ts",
    "test:lighthouse": "node scripts/run-with-verification-environment.mjs pnpm run test:lighthouse:configured",
    "test:lighthouse:configured": "pnpm --filter @lumen/web build && start-server-and-test 'node scripts/start-test-production-server.mjs' http-get://127.0.0.1:3100/api/health 'lhci autorun'",
    "test:load": "start-server-and-test 'node scripts/start-test-development-server.mjs' http-get://127.0.0.1:3100/api/health 'k6 run k6/smoke.js'",
    "test:hosted:preview": "node scripts/run-hosted-smoke.mjs preview",
    "test:hosted:preview:content": "node scripts/run-hosted-content-acceptance.mjs",
    "test:hosted:preview:srs": "node scripts/run-hosted-srs-acceptance.mjs",
    "test:hosted:production": "node scripts/run-hosted-smoke.mjs production",
    "typecheck": "turbo run typecheck",
    "worker:media-deletions": "pnpm --filter @lumen/worker media:deletions",
    "verify": "node scripts/run-with-verification-environment.mjs pnpm run verify:configured",
    "verify:configured": "pnpm format:check && pnpm secret:scan && pnpm lint && pnpm typecheck && pnpm test && pnpm db:reset && pnpm test:db && pnpm db:types:check && pnpm build && pnpm build:portable && pnpm test:e2e && pnpm test:a11y && pnpm test:lighthouse:configured && pnpm test:load"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.5",
    "@lhci/cli": "0.15.1",
    "@next/bundle-analyzer": "16.2.10",
    "@playwright/test": "1.61.1",
    "@rolldown/binding-darwin-x64": "^1.2.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-boundaries": "7.0.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "fast-check": "4.9.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "secretlint": "13.0.2",
    "start-server-and-test": "3.0.11",
    "supabase": "2.109.1",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
