# Public values are bundled into the browser. Never put a secret in a NEXT_PUBLIC_* variable.
NEXT_PUBLIC_APP_NAME=Lumen
# Local development may use HTTP. Both public URLs must use HTTPS in production.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3100
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key

# Server-only values. Copy this file to .env.local and replace local placeholders.
SUPABASE_SECRET_KEY=replace-with-local-secret-key
# The web application uses Supabase HTTP APIs. DATABASE_URL is local tooling or a future
# direct-Postgres worker credential and must remain server-only; it is not required on Vercel.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DEPLOYMENT_PROFILE=local
ENABLE_CHILD_PROFILES=false
ENABLE_PUBLIC_CHILD_CONTENT=false
ENABLE_FREE_TEXT_GAME_CHAT=false
PARENTAL_CONSENT_MODE=disabled
# The current production parser forces child/public/chat capabilities and consent mode off on every host.
# external_verified is available only for nonproduction Cloudflare-shaped adapter tests
# until an independent opaque managed-learner BFF identity is implemented. Both values are server-only.
# PARENTAL_CONSENT_VERIFIER_URL=https://consent-provider.example/v1/verify
# PARENTAL_CONSENT_VERIFIER_API_KEY=replace-with-provider-api-key

# Supabase calls Microsoft OAuth "azure". These flags control button visibility only;
# provider credentials belong in the Supabase dashboard, never this file.
AUTH_EMAIL_CONFIRMATION_REQUIRED=false
AUTH_OAUTH_GOOGLE_ENABLED=false
AUTH_OAUTH_GITHUB_ENABLED=false
AUTH_OAUTH_AZURE_ENABLED=false

# Identity/privacy lifecycle defaults.
PROFILE_SESSION_TTL_MINUTES=30
GUEST_SESSION_RETENTION_HOURS=24
EXPORT_DOWNLOAD_RETENTION_DAYS=7
DELETION_GRACE_PERIOD_DAYS=30
AUDIT_EVENT_RETENTION_DAYS=365

# Shared fixed-window defaults; route implementations enforce separate buckets.
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_SIGNUP_ATTEMPTS=5
RATE_LIMIT_PASSWORD_RESET_ATTEMPTS=5
RATE_LIMIT_PROFILE_PIN_ATTEMPTS=5
RATE_LIMIT_GUEST_CREATION_ATTEMPTS=20
RATE_LIMIT_DESTRUCTIVE_REQUEST_ATTEMPTS=3
APP_ENCRYPTION_KEY=local-only-32-byte-minimum-encryption-key
GUEST_TOKEN_SIGNING_KEY=local-only-32-byte-minimum-signing-key

# Use one stable value across all instances in a deployment. Generate at least 32 random bytes.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Optional build metadata (safe to expose).
NEXT_PUBLIC_BUILD_VERSION=development

# VERCEL, VERCEL_ENV, VERCEL_URL, and VERCEL_GIT_COMMIT_SHA are provider-managed and
# must not be set for local development. Preview derives its exact app origin from VERCEL_URL.
