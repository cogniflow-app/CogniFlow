# Public values are bundled into the browser. Never put a secret in a NEXT_PUBLIC_* variable.
NEXT_PUBLIC_APP_NAME=Lumen
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3100
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key

# Server-only values. Copy this file to .env.local and replace local placeholders.
SUPABASE_SECRET_KEY=replace-with-local-secret-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DEPLOYMENT_PROFILE=local
ENABLE_CHILD_PROFILES=false
ENABLE_PUBLIC_CHILD_CONTENT=false
ENABLE_FREE_TEXT_GAME_CHAT=false
APP_ENCRYPTION_KEY=local-only-32-byte-minimum-encryption-key
GUEST_TOKEN_SIGNING_KEY=local-only-32-byte-minimum-signing-key

# Use one stable value across all instances in a deployment. Generate at least 32 random bytes.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Optional build metadata (safe to expose).
NEXT_PUBLIC_BUILD_VERSION=development
VERCEL_ENV=development
