{
  "name": "@lumen/test-utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./fixtures": {
      "types": "./src/fixtures.ts",
      "default": "./src/fixtures.ts"
    }
  },
  "scripts": {
    "lint": "eslint src tests --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lumen/domain": "workspace:*"
  }
}
