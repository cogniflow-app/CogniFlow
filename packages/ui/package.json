{
  "name": "@lumen/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src/assets",
    "src/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./button": {
      "types": "./src/components/button.tsx",
      "import": "./src/components/button.tsx",
      "default": "./src/components/button.tsx"
    },
    "./content": {
      "types": "./src/components/content.tsx",
      "import": "./src/components/content.tsx",
      "default": "./src/components/content.tsx"
    },
    "./shells": {
      "types": "./src/components/shells.tsx",
      "import": "./src/components/shells.tsx",
      "default": "./src/components/shells.tsx"
    },
    "./styles.css": "./src/styles.css",
    "./assets/*": "./src/assets/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.16",
    "@radix-ui/react-avatar": "1.2.2",
    "@radix-ui/react-checkbox": "1.3.7",
    "@radix-ui/react-context-menu": "2.3.3",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-progress": "1.1.12",
    "@radix-ui/react-radio-group": "1.4.3",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-toast": "1.2.19",
    "@radix-ui/react-tooltip": "1.2.12",
    "@radix-ui/react-visually-hidden": "1.2.7",
    "clsx": "2.1.1",
    "motion": "12.42.2",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/jest-axe": "3.5.9",
    "@vitest/coverage-v8": "4.1.10",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
